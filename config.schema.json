{
  "pluginAlias": "SomfyRpitx",
  "pluginType": "platform",
  "singular": true,
  "strictValidation": false,
  "headerDisplay": "### Somfy RTS 블라인드 설정\n\n처음 설치하면 **블라인드 3개 + 전체 블라인드 1개**가 준비됩니다. 이름과 이동 시간만 맞추면 됩니다. 고유 ID는 모터 등록 후 바꾸지 마십시오.",
  "footerDisplay": "### 등록 방법\n\n개별 항목은 해당 모터 하나에만 PROG 등록하고, **전체 그룹**은 같은 가상 리모컨을 제어할 모든 모터에 각각 등록하십시오. 저장 후 Homebridge를 재시작하면 적용됩니다. [README](https://github.com/AppStudioLB/somfy-rpitx#homebridge-%EC%A0%84%EB%8F%99-%EB%B8%94%EB%9D%BC%EC%9D%B8%EB%93%9C-%EB%93%B1%EB%A1%9D)",
  "schema": {
    "type": "object",
    "required": [
      "name",
      "blinds"
    ],
    "additionalProperties": true,
    "properties": {
      "name": {
        "title": "플랫폼 이름",
        "description": "Homebridge 로그에 표시되는 이름입니다.",
        "type": "string",
        "default": "Somfy rpitx"
      },
      "blinds": {
        "title": "블라인드와 전체 그룹",
        "description": "개별 제어 항목과 여러 모터를 동시에 움직이는 그룹 항목을 추가하십시오. + 버튼으로 더 추가하거나 필요 없는 예제는 삭제할 수 있습니다.",
        "type": "array",
        "minItems": 1,
        "default": [
          {
            "id": "blind-1",
            "name": "블라인드 1",
            "remoteType": "individual",
            "openTimeSeconds": 25,
            "closeTimeSeconds": 25
          },
          {
            "id": "blind-2",
            "name": "블라인드 2",
            "remoteType": "individual",
            "openTimeSeconds": 25,
            "closeTimeSeconds": 25
          },
          {
            "id": "blind-3",
            "name": "블라인드 3",
            "remoteType": "individual",
            "openTimeSeconds": 25,
            "closeTimeSeconds": 25
          },
          {
            "id": "all-blinds",
            "name": "전체 블라인드",
            "remoteType": "group",
            "openTimeSeconds": 25,
            "closeTimeSeconds": 25
          }
        ],
        "items": {
          "title": "블라인드 또는 그룹",
          "type": "object",
          "required": [
            "id",
            "name",
            "openTimeSeconds",
            "closeTimeSeconds"
          ],
          "additionalProperties": true,
          "properties": {
            "name": {
              "title": "HomeKit 표시 이름",
              "description": "예: 거실 왼쪽, 안방, 전체 블라인드",
              "type": "string",
              "default": "새 블라인드"
            },
            "remoteType": {
              "title": "제어 종류",
              "description": "전체 그룹은 이 가상 리모컨을 여러 모터에 동일하게 PROG 등록합니다.",
              "type": "string",
              "default": "individual",
              "oneOf": [
                {
                  "title": "개별 블라인드",
                  "enum": [
                    "individual"
                  ]
                },
                {
                  "title": "전체/그룹 블라인드",
                  "enum": [
                    "group"
                  ]
                }
              ]
            },
            "id": {
              "title": "고유 ID",
              "description": "영문자 또는 숫자로 시작하고 영문자·숫자·점·밑줄·하이픈만 사용할 수 있습니다. 예: living-left, blind-2, all-blinds. 모터 등록 후에는 변경하지 마십시오.",
              "type": "string",
              "default": "new-blind",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
            },
            "openTimeSeconds": {
              "title": "완전히 열리는 시간(초)",
              "description": "완전히 닫힌 상태에서 완전히 열릴 때까지 스톱워치로 측정한 값입니다.",
              "type": "number",
              "minimum": 1,
              "maximum": 600,
              "default": 25
            },
            "closeTimeSeconds": {
              "title": "완전히 닫히는 시간(초)",
              "description": "완전히 열린 상태에서 완전히 닫힐 때까지 스톱워치로 측정한 값입니다.",
              "type": "number",
              "minimum": 1,
              "maximum": 600,
              "default": 25
            }
          }
        }
      }
    }
  }
}
